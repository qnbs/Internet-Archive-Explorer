# Gemini AI — Bring Your Own Key (recommended)
# Add your key in the app: Settings → AI Features → Gemini API Key
# Keys are stored only in your browser (sessionStorage), never in this file for production use.

# Optional: dev-only fallback when VITE_ALLOW_BUILD_TIME_GEMINI_KEY=true (never use in production builds)
# VITE_ALLOW_BUILD_TIME_GEMINI_KEY=true
# VITE_API_KEY=your-gemini-api-key

VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_RECROOM_OPEN_ON_ARCHIVE=false

# Optional: enable verbose client logs (logger.warn/debug) in production builds (default: off)
# VITE_DEBUG_LOGS=true
