    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "gh-pages": "^6.3.0",
    "jotai": "^2.14.0",
    "postcss": "^8.5.8",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.4",
    "uuid": "^10.0.0",
    "vite": "^7.1.5",
    "vite-bundle-analyzer": "^1.3.7"
