{
  "name": "internet-archive-explorer",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.6.1",
  "homepage": "https://qnbs.github.io/Internet-Archive-Explorer",
  "type": "module",
  "scripts": {
    "postinstall": "pnpm audit --audit-level=moderate || true",
    "sync:locales": "node scripts/sync-locales.mjs",
    "prebuild": "pnpm run sync:locales",
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "lint:fix": "biome check --write .",
    "check": "biome ci . && tsc --noEmit",
    "check:i18n": "node scripts/sync-locales.mjs --check",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:commit-msg": "node scripts/check-commit-msg.mjs",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:fix": "pnpm audit fix --audit-level=moderate",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.90.21",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.35.1",
    "lucide-react": "^1.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.13.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.13",
    "@google/genai": "^1.19.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "gh-pages": "^6.3.0",
    "jotai": "^2.14.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "uuid": "^14.0.0",
    "vite": "^8.0.8",
    "vite-bundle-analyzer": "^1.3.7"
  },
  "overrides": {
    "rimraf": "3.0.2",
    "glob": "^11.0.0",
    "inflight": "1.0.6"
  }
}
